_tixRecordFlags <FocusOut> % 107508 ?? ?? ?? NotifyVirtual ?? ?? ?? NotifyNormal ?? ?? ?? ?? ?? ?? ?? ?? ?? 0 ?? ?? ?? ?? 10 .icon.mode ?? ??; 
	if {[string equal NotifyVirtual NotifyNonlinear] ||
	    [string equal NotifyVirtual NotifyNonlinearVirtual]} {
 	    if {[info exists .icon.mode(cancelTab)]} {
		unset .icon.mode(cancelTab)
	    } else {
		if {[set .icon.mode(-state)] ne "disabled"} {
		    if {[set .icon.mode(-selection)] ne [set .icon.mode(-value)]} {
			tixComboBox:Invoke .icon.mode
		    }
		}
	    }
	}
    ; _tixDeleteFlags;
     tk::ButtonEnter .icon.mode.frame.arrow
     tk::ButtonLeave .icon.mode.frame.arrow
