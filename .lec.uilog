	set tk::Priv(activeBg) [.keymgr.pane.com.revised.list.hsb cget -activebackground]
	.keymgr.pane.com.revised.list.hsb configure -activebackground [.keymgr.pane.com.revised.list.hsb cget -background]
    }
    .keymgr.pane.com.revised.list.hsb activate [.keymgr.pane.com.revised.list.hsb identify 441 8]
     if {$tk_strictMotif && [info exists tk::Priv(activeBg)]} {
	.keymgr.pane.com.revised.list.hsb configure -activebackground $tk::Priv(activeBg)
    }
    .keymgr.pane.com.revised.list.hsb activate {}
     if {$tk_strictMotif} {
	set tk::Priv(activeBg) [.keymgr.pane.com.vbar cget -activebackground]
	.keymgr.pane.com.vbar configure -activebackground [.keymgr.pane.com.vbar cget -background]
    }
    .keymgr.pane.com.vbar activate [.keymgr.pane.com.vbar identify 7 284]
     if {$tk_strictMotif && [info exists tk::Priv(activeBg)]} {
	.keymgr.pane.com.vbar configure -activebackground $tk::Priv(activeBg)
    }
    .keymgr.pane.com.vbar activate {}
