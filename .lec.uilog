	if {"NotifyVirtual" eq "NotifyNonlinear" || "NotifyVirtual" eq "NotifyNonlinearVirtual"} {
	    focus [.icon.mode subwidget entry]
 	    # CYGNUS: Setting the selection if there is no data
	    # causes backspace to misbehave.
	    if {[[set .icon.mode(w:entry)] get] ne ""} {
  		[set .icon.mode(w:entry)] selection from 0
  		[set .icon.mode(w:entry)] selection to end
  	    }
 	}
    ; _tixDeleteFlags;
